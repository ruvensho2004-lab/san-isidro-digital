generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Solicitud {
  id          Int      @id @default(autoincrement())
  nombre      String
  cedula      String?
  telefono    String?
  tipo        String
  descripcion String
  estado      String   @default("Pendiente")
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}

model RecursoClap {
  id            Int      @id @default(autoincrement())
  nombre        String
  cedula        String
  tipo          String
  cantidad      Int      @default(1)
  observaciones String?
  estado        String   @default("Pendiente")
  pagado        Boolean  @default(false)
  fecha         DateTime @default(now())
  actualizado   DateTime @updatedAt
}

model Emprendimiento {
  id               Int      @id @default(autoincrement())
  nombre           String
  cedula           String?
  responsable      String
  categoria        String
  descripcion      String
  cumpleRequisitos Boolean  @default(false)
  estado           String   @default("Pendiente")
  inversion        Decimal?
  fecha            DateTime @default(now())
  actualizado      DateTime @updatedAt
}

model Proyecto {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String
  tipo        String
  sector      String
  presupuesto Decimal? @default(0)
  estado      String   @default("En Planificación")
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}

model Beneficiario {
  id          Int      @id @default(autoincrement())
  nombre      String
  cedula      String   @unique
  telefono    String?
  direccion   String?
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  rol       String   @default("usuario")
  cedula    String   @unique
  nombre    String
  apellido  String?
  telefono  String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GasComunal {
  id          Int      @id @default(autoincrement())
  responsable String
  cedula      String
  tamano      String   // "10Kg", "18Kg", "27Kg", "43Kg"
  cantidad    Int      @default(1)
  estado      String   @default("Pendiente") // Pendiente, Entregado, Vacío
  pagado      Boolean  @default(false)
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}

model Asamblea {
  id          Int      @id @default(autoincrement())
  motivo      String
  fecha       DateTime @default(now())
  asistentes  Int      @default(0)
  acuerdos    String
  vocero      String?
  enlaceActa  String?
  actualizado DateTime @updatedAt
}

model CasoSalud {
  id          Int      @id @default(autoincrement())
  paciente    String
  cedula      String?
  diagnostico String
  ayudaReq    String
  estado      String   @default("Revisión") // Revisión, Atendido, Rechazado
  prioridad   String   @default("Normal")   // Normal, Alta, Emergencia
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}

model Noticia {
  id          Int      @id @default(autoincrement())
  titulo      String
  contenido   String
  tipo        String   @default("General") // Asamblea, Salud, General, Alerta
  activa      Boolean  @default(true)
  fecha       DateTime @default(now())
  actualizado DateTime @updatedAt
}
